# LLM Provider Configuration
# Options: anthropic, openai
LLM_PROVIDER=anthropic

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20251022

# OpenAI / OpenAI-compatible Configuration
# Set OPENAI_BASE_URL to use third-party providers (147api, DeepSeek, etc.)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.147api.com/v1

# Behavior Control
MAX_ITERATIONS=10
COMPRESSION_THRESHOLD=150000
WORK_DIR=.

# UI Mode
# Options: tui, simple
UI_MODE=tui
